# Copy to .env and fill in your values
# Run with: TEST_ENV=staging npx playwright test (for staging)

BASE_URL=https://www.saucedemo.com
STANDARD_USER=<your-test-username>
LOCKED_USER=<your-locked-user>
PROBLEM_USER=<your-problem-user>
PERF_USER=<your-perf-user>
PASSWORD=<your-test-password>
TEST_ENV=production
